{
    "name": "dev-3bdulrahman/manufacturing",
    "description": "A Manufacturing module for Laravel ERP — BOM, Work Centers, Production Orders, Work Orders & Material Consumption.",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulrahman",
            "homepage": "https://3bdulrahman.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dev3bdulrahman\\Manufacturing\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dev3bdulrahman\\Manufacturing\\Providers\\ManufacturingServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
